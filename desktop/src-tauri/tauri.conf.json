{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lava Playground",
  "version": "1.0.0",
  "identifier": "com.yesucs.lavaplayground",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lava Playground",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:5133 http://127.0.0.1:8000 https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "shortDescription": "Write Lava, watch it flow.",
    "longDescription": "A standalone playground for Rock RMS-style Lava templates: live render, filter reference, and a linter.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/lava-api",
      "binaries/lava-linter"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
