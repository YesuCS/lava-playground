<?xml version="1.0" encoding="utf-8"?>
<!-- Used ONLY for the desktop self-contained publish, which must restore the
     osx runtime packs from nuget.org. The repo's api/nuget.config clears all
     sources for offline builds; this file overrides that for packaging. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
