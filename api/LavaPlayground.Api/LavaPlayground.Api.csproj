<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- Embedded (not copied) so the sample data travels inside the single-file
         self-contained binary used by the desktop app, with no side files.
         Read back via reflection in Program.cs. -->
    <EmbeddedResource Include="SampleData\sample-context.json" />
    <EmbeddedResource Include="SampleData\sample-entities.json" />
  </ItemGroup>

</Project>
